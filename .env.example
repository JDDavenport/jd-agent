# JD Agent - Environment Variables

# ============================================
# DATABASE (REQUIRED)
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/jd_agent

# ============================================
# AI SERVICES (REQUIRED FOR CLASSIFICATION)
# ============================================
ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================
# MIGRATION SOURCES (OPTIONAL)
# ============================================

# Notion - Get from: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxx

# Todoist - Get from: https://todoist.com/app/settings/integrations/developer
TODOIST_API_KEY=xxx

# Google OAuth2 (Drive & Docs)
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REFRESH_TOKEN=xxx

# Apple Notes - No key needed, runs via AppleScript on macOS

# ============================================
# EXISTING INTEGRATIONS
# ============================================

# Linear
LINEAR_API_KEY=xxx

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS={"type":"service_account",...}

# Canvas
CANVAS_API_TOKEN=xxx
CANVAS_API_URL=https://canvas.instructure.com

# Telegram
TELEGRAM_BOT_TOKEN=xxx

# ReMarkable
REMARKABLE_TOKEN=xxx

# Plaud
PLAUD_API_KEY=xxx

# Deepgram (transcription)
DEEPGRAM_API_KEY=xxx

# Voyage AI (embeddings)
VOYAGE_API_KEY=xxx

# Twilio (SMS)
TWILIO_ACCOUNT_SID=xxx
TWILIO_AUTH_TOKEN=xxx
TWILIO_PHONE_NUMBER=xxx

# Resend (Email)
RESEND_API_KEY=xxx

# Whoop (health & fitness)
WHOOP_CLIENT_ID=xxx
WHOOP_CLIENT_SECRET=xxx
WHOOP_REDIRECT_URI=http://localhost:3000/api/whoop/callback

# Redis (for BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
