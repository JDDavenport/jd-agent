# JD Agent - Staging Environment Template
# Copy to .env.staging and fill in your Neon staging database credentials

NODE_ENV=staging
APP_ENV=staging
PORT=3000

# Neon PostgreSQL - Staging Branch
# Create a staging branch in your Neon project
DATABASE_URL=postgresql://user:password@your-project-staging.neon.tech/jd_agent_staging?sslmode=require
DATABASE_SSL=true
DATABASE_POOL_SIZE=5

# Redis (if using managed Redis for staging)
REDIS_URL=redis://your-staging-redis:6379

# AI Providers - Use same keys as production or separate staging keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
GOOGLE_AI_API_KEY=AIza...

# Transcription
DEEPGRAM_API_KEY=your_deepgram_key

# Cloud Storage - Use separate staging bucket
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET_NAME=jd-agent-staging

# Integrations
NOTION_TOKEN=secret_...
TODOIST_API_TOKEN=your_todoist_token
WHOOP_CLIENT_ID=your_client_id
WHOOP_CLIENT_SECRET=your_client_secret
WHOOP_REDIRECT_URI=https://staging.yourdomain.com/api/whoop/callback

# Security
JWT_SECRET=your-staging-jwt-secret-32-chars-min
ENCRYPTION_KEY=your-staging-encryption-key

# Feature flags
ENABLE_AI_FEATURES=true
ENABLE_QUEUE_PROCESSING=true

# Logging - more verbose for staging debugging
LOG_LEVEL=debug
