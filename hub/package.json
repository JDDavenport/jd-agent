{
  "name": "@jd-agent/hub",
  "version": "0.1.0",
  "description": "JD Agent Hub - Backend API",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "worker": "bun run src/worker.ts",
    "scheduler": "bun run src/scheduler.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate:dev": "bun run scripts/db/migrate.ts development",
    "db:migrate:staging": "bun run scripts/db/migrate.ts staging",
    "db:migrate:prod": "bun run scripts/db/migrate.ts production",
    "db:seed:staging": "APP_ENV=staging bun run scripts/db/seed-staging.ts",
    "db:verify": "bun run scripts/db/verify.ts",
    "db:verify:all": "bun run scripts/db/verify.ts --all",
    "typecheck": "tsc --noEmit",
    "migrate:recover": "bun run src/migration/smart-data-recovery.ts",
    "migrate:recover:dry": "bun run src/migration/smart-data-recovery.ts --dry-run",
    "migrate:recover:apple": "bun run src/migration/smart-data-recovery.ts --execute --source=apple-notes",
    "migrate:recover:notion": "bun run src/migration/smart-data-recovery.ts --execute --source=notion",
    "migrate:recover:todoist": "bun run src/migration/smart-data-recovery.ts --execute --source=todoist",
    "migrate:recover:drive": "bun run src/migration/smart-data-recovery.ts --execute --source=google-drive",
    "migrate:cleanup": "bun run src/migration/vault-cleanup.ts",
    "migrate:organize": "bun run src/migration/vault-organize.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:legacy": "bun run scripts/test-all.ts",
    "test:goals": "bun run scripts/test-goals.ts",
    "test:vip": "bun run scripts/test-vip.ts",
    "test:ai": "bun run scripts/run-ai-tests.ts",
    "test:ai:full": "bun run scripts/run-ai-tests.ts --scope full",
    "test:ai:smoke": "bun run scripts/run-ai-tests.ts --scope smoke",
    "test:critical": "bun run scripts/test-critical-paths.ts",
    "test:critical-5x": "TEST_RETRIES=5 bun run scripts/test-critical-paths.ts",
    "test:critical-3x": "TEST_RETRIES=3 bun run scripts/test-critical-paths.ts",
    "test:vault-ios": "bun run scripts/vault-ios-test-suite.ts",
    "test:vault-ios:build": "bun run scripts/vault-ios-test-suite.ts --build-only",
    "test:vault-ios:api": "bun run scripts/vault-ios-test-suite.ts --api-only",
    "verify": "bun run scripts/verify-db.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.962.0",
    "@better-auth/stripe": "^1.2.0",
    "better-auth": "^1.2.0",
    "@deepgram/sdk": "^3.9.0",
    "@doist/todoist-api-typescript": "^6.2.1",
    "@google-cloud/vision": "^4.3.2",
    "@google/generative-ai": "^0.24.1",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.7.6",
    "@notionhq/client": "^5.6.0",
    "bullmq": "^5.30.1",
    "canvas": "^3.2.1",
    "cheerio": "^1.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.37.0",
    "googleapis": "^144.0.0",
    "groq-sdk": "^0.37.0",
    "hono": "4.6.14",
    "ioredis": "^5.4.1",
    "mammoth": "^1.11.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.12",
    "openai": "^6.15.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "1.1.4",
    "pdf-to-img": "^5.0.0",
    "pdfjs-dist": "^5.4.530",
    "pg": "^8.13.1",
    "plaid": "^41.0.0",
    "playwright": "^1.57.0",
    "postgres": "^3.4.8",
    "resend": "^4.0.1",
    "stripe": "^17.0.0",
    "rrule": "^2.8.1",
    "tesseract.js": "^7.0.0",
    "turndown": "^7.2.2",
    "twilio": "^5.4.0",
    "voyageai": "^0.0.3-1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/turndown": "^5.0.6",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "bun-types": "^1.3.6",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16"
  }
}
