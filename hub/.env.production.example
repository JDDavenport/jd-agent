# JD Agent - Production Environment Template
# Copy to .env.production and fill in your Neon production database credentials
# CRITICAL: Never commit production credentials to git!

NODE_ENV=production
APP_ENV=production
PORT=3000

# Neon PostgreSQL - Production (Main Branch)
# Use your Neon project's main branch for production
DATABASE_URL=postgresql://user:password@your-project.neon.tech/jd_agent?sslmode=require
DATABASE_SSL=true
DATABASE_POOL_SIZE=20

# Redis (managed Redis recommended for production)
REDIS_URL=redis://your-production-redis:6379

# AI Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GROQ_API_KEY=gsk_...
GOOGLE_AI_API_KEY=AIza...

# Transcription
DEEPGRAM_API_KEY=your_deepgram_key

# Cloud Storage - Production bucket
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET_NAME=jd-agent-production

# Integrations
NOTION_TOKEN=secret_...
TODOIST_API_TOKEN=your_todoist_token
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
WHOOP_CLIENT_ID=your_client_id
WHOOP_CLIENT_SECRET=your_client_secret
WHOOP_REDIRECT_URI=https://yourdomain.com/api/whoop/callback

# Security - CRITICAL: Use strong, unique values
JWT_SECRET=your-production-jwt-secret-must-be-at-least-32-characters
ENCRYPTION_KEY=your-production-encryption-key

# Feature flags
ENABLE_AI_FEATURES=true
ENABLE_QUEUE_PROCESSING=true

# Logging - minimal for production
LOG_LEVEL=warn
