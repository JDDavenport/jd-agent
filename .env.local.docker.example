# JD Agent - Docker Environment Variables
# Copy this file to .env.local.docker and fill in your values
#
# IMPORTANT: Never commit .env.local.docker to git!

# ============================================
# Database Configuration (set in docker-compose)
# ============================================
# These are set by docker-compose.yml, but you can override:
# POSTGRES_USER=jdagent
# POSTGRES_PASSWORD=jdagent_local_pass
# POSTGRES_DB=jd_agent

# ============================================
# AI API Keys (Required for AI features)
# ============================================
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENAI_API_KEY=sk-...

# ============================================
# Cloudflare Tunnel (Required for webhooks)
# ============================================
# Get this from: https://one.dash.cloudflare.com/ → Zero Trust → Access → Tunnels
CLOUDFLARE_TUNNEL_TOKEN=eyJhIjoiY...

# ============================================
# Integration API Keys (Optional - enable as needed)
# ============================================

# Email (Resend)
RESEND_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Google Calendar/Gmail
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Notion Integration
NOTION_API_KEY=
NOTION_DATABASE_ID=

# Todoist
TODOIST_API_KEY=

# Linear
LINEAR_API_KEY=

# Canvas LMS
CANVAS_API_TOKEN=
CANVAS_API_URL=

# Plaud (Voice Recording)
PLAUD_API_KEY=

# Deepgram (Transcription)
DEEPGRAM_API_KEY=

# Voyage AI (Embeddings)
VOYAGE_API_KEY=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Whoop (Health Tracking)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=

# reMarkable
REMARKABLE_TOKEN=

# Garmin
GARMIN_EMAIL=
GARMIN_PASSWORD=

# ============================================
# Security
# ============================================
JWT_SECRET=generate-a-random-32-char-string
ENCRYPTION_KEY=generate-another-random-32-char-string

# ============================================
# Cloudflare R2 (Object Storage)
# ============================================
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=

# ============================================
# Feature Flags
# ============================================
ENABLE_AI_FEATURES=true
ENABLE_QUEUE_PROCESSING=true
