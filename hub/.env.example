# JD Agent - Environment Configuration Template
# Copy this file to .env and fill in your values
# For environment-specific configs, use .env.development, .env.staging, .env.production

# ===========================================
# CORE SETTINGS
# ===========================================
NODE_ENV=development
APP_ENV=development
PORT=3000

# ===========================================
# DATABASE - Neon PostgreSQL
# ===========================================
# Get your connection string from https://neon.tech
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/jd_agent_dev?sslmode=require
DATABASE_SSL=true
DATABASE_POOL_SIZE=10

# ===========================================
# REDIS (Optional - for queue processing)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# AI PROVIDERS
# ===========================================
# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic Claude - https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Groq (Free tier) - https://console.groq.com/
GROQ_API_KEY=gsk_...

# Google AI (Free tier) - https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY=AIza...

# ===========================================
# TRANSCRIPTION
# ===========================================
# Deepgram - https://console.deepgram.com/
DEEPGRAM_API_KEY=your_deepgram_key

# ===========================================
# CLOUD STORAGE (Cloudflare R2)
# ===========================================
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET_NAME=jd-agent-recordings

# ===========================================
# INTEGRATIONS (Optional)
# ===========================================
# Notion - https://www.notion.so/my-integrations
NOTION_TOKEN=secret_...

# Todoist - https://todoist.com/app/settings/integrations/developer
TODOIST_API_TOKEN=your_todoist_token

# Google Calendar
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token

# Whoop - https://developer.whoop.com/
WHOOP_CLIENT_ID=your_client_id
WHOOP_CLIENT_SECRET=your_client_secret
WHOOP_REDIRECT_URI=http://localhost:3000/api/whoop/callback

# ===========================================
# SECURITY
# ===========================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your-32-character-or-longer-secret
ENCRYPTION_KEY=your-encryption-key

# ===========================================
# FEATURE FLAGS
# ===========================================
ENABLE_AI_FEATURES=true
ENABLE_QUEUE_PROCESSING=true

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=info
